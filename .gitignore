# .gitignore
# ============================
# Python
# ============================
__pycache__/
*.pyc
*$py.class

# ============================
# Virtual environments
# ============================
.venv/
venv/
env/
ENV/

# ============================
# Environment variables
# ============================
.env
.env.*

# ============================
# Django
# ============================
*.log
db.sqlite3
db.sqlite3-journal
local_settings.py

# ============================
# Static & media (runtime)
# ============================
staticfiles/
media/

# ============================
# IDE / Editors
# ============================
.idea/
.vscode/

# ============================
# Caches
# ============================
.pytest_cache/
.mypy_cache/
.dmypy.json
.cache/

# ============================
# Build / packaging
# ============================
*.egg-info/
dist/
build/

# ============================
# OS files
# ============================
.DS_Store
Thumbs.db
